# SaaSyToad Forge - environment template.
# Copy to .env.local (web) / .env (agent-service) and fill in. NEVER commit real values.
# Secrets are optional at boot: missing ones degrade to mock providers (see DECISIONS.md).

# ---- Models (OpenRouter) ----
OPENROUTER_API_KEY=
# Model routing. Overridable; never hardcoded in business logic.
MODEL_FAST=openai/gpt-4o-mini
MODEL_FRONTIER=anthropic/claude-sonnet-4
MODEL_DEEP=openrouter/fusion

# ---- Sandbox ----
# mock | e2b | daytona
SANDBOX_PROVIDER=mock
E2B_API_KEY=
# Comma-separated egress allowlist applied to every sandbox (default-deny).
EGRESS_ALLOWLIST=registry.npmjs.org,registry.yarnpkg.com,pypi.org

# ---- Supabase (Postgres + Auth) ----
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- Stripe (billing scaffold; no live charges without approval) ----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=


# ---- Spend caps (USD) ----
SPEND_CAP_USER_USD=5
SPEND_CAP_GLOBAL_USD=100

# ---- Agent service ----
PORT=8787

# ---- Web -> agent-service wiring (client-safe) ----
NEXT_PUBLIC_AGENT_SERVICE_URL=http://localhost:8787
