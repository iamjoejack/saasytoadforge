# SaaSyToad Forge - environment template.
# Copy to .env.local (web) / .env (agent-service) and fill in. NEVER commit real values.
# Secrets are optional at boot: missing ones degrade to mock providers (see DECISIONS.md).

# ---- Models (OpenRouter) ----
OPENROUTER_API_KEY=
# Model routing. Overridable; never hardcoded in business logic.
MODEL_FAST=openai/gpt-4o-mini
MODEL_FRONTIER=anthropic/claude-sonnet-4
MODEL_DEEP=openrouter/fusion

# ---- Claude / Gemini direct (optional) ----
# Set ANTHROPIC_API_KEY to drive Claude directly (no OpenRouter needed). Users can also
# paste their own key in Settings. ANTHROPIC_MODEL must support adaptive thinking; never claude-3-*.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
GOOGLE_MODEL=gemini-2.5-pro

# ---- Sandbox ----
# mock | e2b | daytona
SANDBOX_PROVIDER=mock
E2B_API_KEY=
# Comma-separated egress allowlist applied to every sandbox (default-deny).
EGRESS_ALLOWLIST=registry.npmjs.org,registry.yarnpkg.com,pypi.org

# ---- Supabase (Postgres + Auth) ----
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- Stripe (billing scaffold; no live charges without approval) ----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Stripe Price ids for live checkout (leave blank in dev to use the mock provider).
STRIPE_PRICE_PRO=
STRIPE_PRICE_TOPUP_10=
# Public web origin used for Stripe success/cancel redirects.
PUBLIC_URL=http://localhost:3000

# ---- Integrations & Developer API Extensions ----
UPSTASH_REDIS_REST_URL=
RESEND_API_KEY=
VERCEL_TOKEN=
ZAPIER_API_KEY=


# ---- Spend caps (USD) ----
# OWNER_EMAILS users bypass ALL spend caps entirely (unlimited access).
SPEND_CAP_USER_USD=50
SPEND_CAP_GLOBAL_USD=500

# ---- Admin & Owner Accounts ----
# ADMIN_EMAILS: comma-separated emails with access to the admin dashboard.
ADMIN_EMAILS=joejackson80@gmail.com,happyvwdude@gmail.com,mojavenouveaux@gmail.com
# OWNER_EMAILS: comma-separated company/founder emails. These accounts have NO spend limits
# and are the only ones that can create or remove admin users.
OWNER_EMAILS=joejackson80@gmail.com,happyvwdude@gmail.com,mojavenouveaux@gmail.com

# ---- Agent service ----
PORT=8787

# ---- Web -> agent-service wiring (client-safe) ----
NEXT_PUBLIC_AGENT_SERVICE_URL=http://localhost:8787
